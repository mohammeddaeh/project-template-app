## 📡 API Service (REST)

### `lib/core/infra/network/rest/api_urls.dart`
```dart
abstract class ApiUrls {
  static const String login = '/auth/login';
  static const String users = '/users';
  static const String {name} = '/your/endpoint';  // add here
}
```

### `lib/Features/{feature}/data/datasources/{feature}_api_service.dart`

```dart
@lazySingleton
@RestApi()
abstract class {Feature}ApiService {
  @factoryMethod
  factory {Feature}ApiService(Dio dio) =>
      _{Feature}ApiService(dio, baseUrl: Env().config.baseUrl);

  // GET with query params:
  @GET(ApiUrls.{name})
  Future<ApiResponse<{Model}>> {methodName}(
    @Query('page') int? page,
    @Query('limit') int? limit,
    @CancelRequest() CancelToken? cancelToken,
  );

  // POST with form fields:
  @POST(ApiUrls.{name})
  Future<ApiResponse<{Model}>> {postMethod}(
    @Field('field1') String field1,
    @Field('field2') String field2,
    @CancelRequest() CancelToken? cancelToken,
  );

  // PATCH with JSON body:
  @PATCH(ApiUrls.{name})
  Future<ApiResponse<{Model}>> {patchMethod}(
    @Path('id') int id,
    @Body() {Request}Request body,
    @CancelRequest() CancelToken? cancelToken,
  );
}
```

