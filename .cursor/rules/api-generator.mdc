import 'package:flutter_base_template/core/foundation/domain/base_usecase.dart';
import 'package:flutter_base_template/core/foundation/errors/failure.dart';
import 'package:flutter_base_template/Features/{feature}/domain/entities/{entity}.dart';
import 'package:flutter_base_template/Features/{feature}/domain/repositories/{feature}_repository.dart';
import 'package:dartz/dartz.dart';
import 'package:injectable/injectable.dart';

@injectable
class {UseCaseName} extends BaseUseCase<Either<Failure, {Entity}>, {Params}> {
  {UseCaseName}(this._repository);
  final {Feature}Repository _repository;

  @override
  Future<Either<Failure, {Entity}>> call(covariant {Params} params) {
    return _repository.{methodName}(params);
  }
}
```

### Domain Params (UseCase input)
```dart
// lib/Features/{feature}/domain/params/{name}_params.dart
// 🚨 MUST extend UseCaseParams — BaseUseCase requires it: BaseUseCase<Result, Params extends UseCaseParams>
import 'package:flutter_base_template/core/foundation/domain/use_case_params.dart';

class {Name}Params extends UseCaseParams {
  final String field1;
  final String? field2;

  const {Name}Params({
    required this.field1,
    this.field2,
  }) : super();   // ← super() is required
}
```

> ⚠️ **`NoParams`** is the alternative when the UseCase takes no input — it already extends `UseCaseParams`.
> Only create a `Params` class when the UseCase needs actual input data.

### Data Model Rules

> 🔑 **REST vs GraphQL — different model patterns:**
>
> | | REST | GraphQL |
> |---|---|---|
> | Model factory | `fromJson(Map<String, dynamic> json)` | `fromGql(GeneratedGqlType gql)` |
> | Entity mapper | `toEntity()` | `toEntity()` (same) |
> | Repository usage | `{Name}Model.fromJson(res.data!.toJson()).toEntity()` | `{Name}Model.fromGql(parsed.{op}).toEntity()` |
> | Sub-models? | Yes — for every nested JSON object | Yes — for every nested GQL object |
>
> ⚠️ **Before writing any model (REST or GQL), read the full response structure:**
> - **REST:** Check the OpenAPI schema for all fields including nested objects
> - **GraphQL:** Read the `.graphql` document — every nested type needs its own Model class with `fromGql` + `toEntity()`
> - Create a separate model class for EVERY nested object. Never write a flat model that ignores nested fields.

### Data Model — REST (manual fromJson + toJson + toEntity)
```dart
// lib/Features/{feature}/data/models/{model}_model.dart
// 🚨 Use EXACT field names from OpenAPI schema

import 'package:flutter_base_template/Features/{feature}/domain/entities/{entity}.dart';

class {Name}Model {
  final int id;       // or String depending on API
  final String field1;
  final String? field2;

  const {Name}Model({required this.id, required this.field1, this.field2});

  factory {Name}Model.fromJson(Map<String, dynamic> json) {
    return {Name}Model(
      id: json['id'] as int? ?? 0,
      field1: json['field1'] as String? ?? '',
      field2: json['field2'] as String?,
    );
  }

  // toJson is required for models used as request bodies or nested in response wrappers
  Map<String, dynamic> toJson() {
    return <String, dynamic>{
      'id': id,
      'field1': field1,
      'field2': field2,
    };
  }

  {Entity} toEntity() => {Entity}(id: id, field1: field1, field2: field2);
}
```

> **For paginated REST responses**, the model is wrapped in a response class:
> ```dart
> // lib/Features/{feature}/data/models/{feature}_response.dart
> class {Feature}Response {
>   final List<{Name}Model> items;
>   final PaginationMeta meta;
>   final PaginationLinks links;
>
>   const {Feature}Response({required this.items, required this.meta, required this.links});
>
>   factory {Feature}Response.fromJson(Map<String, dynamic> json) {
>     return {Feature}Response(
>       items: (json['items'] as List<dynamic>?)
>           ?.map((e) => {Name}Model.fromJson(e as Map<String, dynamic>))
>           .toList() ?? [],
>       meta: PaginationMeta.fromJson(json['meta'] as Map<String, dynamic>),
>       links: PaginationLinks.fromJson(json['links'] as Map<String, dynamic>),
>     );
>   }
> }
> ```
> Copy `PaginationMeta` and `PaginationLinks` from `lib/Features/users/data/models/`.

### Data Model — GraphQL (fromGql + toEntity — NO fromJson)
```dart
// lib/Features/{feature}/data/models/{model}_model.dart
// 🚨 Use fromGql factory — the generated .graphql.dart type handles JSON parsing
// 🚨 Create a separate Model class for EVERY nested type in the GQL response

import 'package:flutter_base_template/core/network/gql/config/documents/{mutations|queries}/generated/{name}.graphql.dart';
import 'package:flutter_base_template/Features/{feature}/domain/entities/{entity}.dart';

// Sub-model for nested GQL type (repeat for every nested object)
class {Sub}Model {
  final String id;
  final String name;

  const {Sub}Model({required this.id, required this.name});

  factory {Sub}Model.fromGql({GqlNestedType} gql) {
    return {Sub}Model(id: gql.id, name: gql.name);
  }

  {SubEntity} toEntity() => {SubEntity}(id: id, name: name);
}

// Main model
class {Name}Model {
  final String id;
  final String field1;
  final List<{Sub}Model> items;

  const {Name}Model({required this.id, required this.field1, required this.items});

  factory {Name}Model.fromGql({GqlType} gql) {
    return {Name}Model(
      id: gql.id,
      field1: gql.field1,
      items: gql.items.map({Sub}Model.fromGql).toList(),
    );
  }

  {Entity} toEntity() => {Entity}(
        id: id,
        field1: field1,
        items: items.map((i) => i.toEntity()).toList(),
      );
}
```

> **Repository usage:**
> ```dart
> // REST
> return Right({Name}Model.fromJson(res.data!.toJson()).toEntity());
>
> // GraphQL
> final parsed = {Mutation|Query}${OpName}.fromJson(res.data as Map<String, dynamic>);
> return Right({Name}Model.fromGql(parsed.{operationName}).toEntity());
> ```

