    required this.currentPage,
  });
}
```

### Paginated Cubit (extends PaginationCubit)
```dart
// lib/Features/{feature}/presentation/cubits/{name}_cubit.dart
import 'package:flutter_base_template/core/foundation/errors/failure.dart';
import 'package:flutter_base_template/core/foundation/contracts/pagination_data_entity.dart';
import 'package:flutter_base_template/presentation/shared/pagination/pagination_cubit.dart';
import 'package:flutter_base_template/Features/{feature}/domain/entities/{entity}.dart';
import 'package:flutter_base_template/Features/{feature}/domain/entities/{name}_page.dart';
import 'package:flutter_base_template/Features/{feature}/domain/params/{name}_params.dart';
import 'package:flutter_base_template/Features/{feature}/domain/usecases/{use_case}.dart';
import 'package:dartz/dartz.dart';
import 'package:injectable/injectable.dart';

// Note: no state file needed — PaginationCubit manages all states internally
@injectable
class {Name}Cubit extends PaginationCubit<{Entity}> {
  {Name}Cubit(this._{useCaseName}) : super();
  final {UseCaseName} _{useCaseName};

  @override
  Future<Either<Failure, PaginationDataEntity<{Entity}>>> call() async {
    final res = await _{useCaseName}(
      {Name}Params(paginationQuery: paginationQuery),
    );

    return res.fold(
      Left.new,
      ({Name}Page page) {
        final isLastPage = paginationQuery.page >= page.totalPages;
        return Right(
          PaginationDataEntity<{Entity}>(
            data: page.items,
            paginationInfo: PaginationInfo(
              isFirstPage: paginationQuery.page == 1,
              isLastPage: isLastPage,
            ),
          ),
        );
      },
    );
  }

  @override
  bool isMatchedTwoEntity({Entity} entity1, {Entity} entity2) {
    return entity1.id == entity2.id;
  }

  // ✅ ALWAYS override close() to cancel in-flight requests
  @override
  Future<void> close() {
    _{useCaseName}.cancel();
    return super.close();
  }
}
```

> **`close()` is mandatory in PaginationCubit subclasses** — always call `_{useCaseName}.cancel()` before `super.close()` to prevent memory leaks when the screen is disposed.

### Paginated Screen
```dart
