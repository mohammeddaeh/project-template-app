### Page Entity (Domain)
```dart
// lib/Features/{feature}/domain/entities/{name}_page.dart
import '{entity}.dart';

class {Name}Page {
  final List<{Entity}> items;
  final int totalPages;
  final int currentPage;

  const {Name}Page({
    required this.items,
