```dart
// lib/Features/{feature}/presentation/cubits/{name}_cubit.dart
import 'package:flutter_base_template/core/foundation/errors/failure.dart';
import 'package:flutter_base_template/presentation/error/failure_ui_mapper.dart';
import 'package:flutter_base_template/Features/{feature}/domain/usecases/{use_case}.dart';
import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:freezed_annotation/freezed_annotation.dart';
import 'package:injectable/injectable.dart';

part '{name}_cubit.freezed.dart';
part '{name}_state.dart';

@injectable
class {Name}Cubit extends Cubit<{Name}State> {
  {Name}Cubit(this._{useCaseName}) : super(const {Name}State.initial());
  final {UseCaseName} _{useCaseName};

  void {methodName}({params}) async {
    emit(const {Name}State.loading());
    final res = await _{useCaseName}({params});
    res.fold(
      (failure) {
        switch (FailureUiMapper.toAction(failure)) {
          case ShowError(:final message): emit({Name}State.error(errorMessage: message));
          case NavigateToLogin(): // handle session expiry
          case Silent(): break;
        }
      },
      (r) => emit(const {Name}State.loaded()),
    );
  }
}
```

