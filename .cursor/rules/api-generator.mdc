### Repository Implementation
```dart
// lib/Features/{feature}/data/repositories/{feature}_repository_impl.dart
import 'package:flutter_base_template/core/foundation/errors/failure.dart';
import 'package:flutter_base_template/core/infra/network/boundary/base_repository.dart';
import 'package:flutter_base_template/core/infra/network/rest/handle_body_response.dart';
import 'package:flutter_base_template/Features/{feature}/data/datasources/{feature}_remote_datasource.dart';
import 'package:flutter_base_template/Features/{feature}/domain/entities/{entity}.dart';
import 'package:flutter_base_template/Features/{feature}/domain/repositories/{feature}_repository.dart';
import 'package:dartz/dartz.dart';
import 'package:injectable/injectable.dart';

// Use @Singleton for stateful (auth) / @LazySingleton for stateless (users, products)
@LazySingleton(as: {Feature}Repository)
class {Feature}RepositoryImpl extends BaseRepository implements {Feature}Repository {
  {Feature}RepositoryImpl(this._remoteDataSource, HandleBodyResponse handler) : super(handler);

  final {Feature}RemoteDataSource _remoteDataSource;

  @override
  Future<Either<Failure, {Entity}>> {methodName}({params}) => handle(() async {
    final res = await _remoteDataSource.{methodName}({params});
    // ✅ Check BOTH: no error AND data is present
    if (res.error == null && res.data != null) {
      // ✅ Use toEntity() to convert the model to a domain entity
      return Right(res.data!.toEntity());
    }
    return Left(BusinessFailure(
      statusCode: res.error?.code ?? 400,
      serverMessage: res.message.isNotEmpty ? res.message : null,
    ));
  });
}
```

> **For paginated REST**, the repository maps the response manually since the response wrapper contains `items` + `meta`:
> ```dart
> return handle(() async {
>   final res = await _remoteDataSource.{methodName}({params});
>   if (res.error == null && res.data != null) {
>     final response = res.data!;
>     final entities = response.items.map((m) => m.toEntity()).toList();
>     return Right({Name}Page(
>       items: entities,
>       totalPages: response.meta.totalPages,
>       currentPage: response.meta.currentPage,
>     ));
>   }
>   return Left(BusinessFailure(statusCode: res.error?.code ?? 400));
> });
> ```
>
> **For void REST (DELETE/POST with no response body):**
> ```dart
> return handle(() async {
>   final res = await _remoteDataSource.{methodName}();
>   if (res.error == null) return const Right(unit);
>   return Left(BusinessFailure(statusCode: res.error?.code ?? 400));
> });
> ```

