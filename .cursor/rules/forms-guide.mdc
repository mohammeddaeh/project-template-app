## 3 · Validators — الدوال الموحّدة

ضعها كـ private methods داخل الـ State أو كـ static methods في ملف مساعد.

```dart
// ✅ Required text
String? _validateRequired(String? v) =>
    (v == null || v.trim().isEmpty) ? LocaleKeys.fieldRequired.tr() : null;

// ✅ Email
String? _validateEmail(String? v) {
  if (v == null || v.trim().isEmpty) return LocaleKeys.fieldRequired.tr();
  if (!RegExp(r'^[\w-.]+@([\w-]+\.)+[\w-]{2,}$').hasMatch(v.trim())) {
    return LocaleKeys.invalidEmail.tr();
  }
  return null;
}

// ✅ Password (8–30 حرف + تعقيد)
String? _validatePassword(String? v) {
  if (v == null || v.isEmpty) return LocaleKeys.fieldRequired.tr();
  if (v.length < 8 || v.length > 30) return LocaleKeys.passwordLength.tr();
  if (!CustomRegex.passwordRegex.hasMatch(v)) return LocaleKeys.passwordWeak.tr();
  return null;
}

// ✅ تأكيد كلمة المرور
String? _validateConfirmPassword(String? v) {
  if (v == null || v.isEmpty) return LocaleKeys.fieldRequired.tr();
  if (v != _passwordCtrl.text) return LocaleKeys.passwordMismatch.tr();
  return null;
}

// ✅ Phone
String? _validatePhone(String? v) {
  if (v == null || v.trim().isEmpty) return LocaleKeys.fieldRequired.tr();
  if (v.trim().length < 9) return LocaleKeys.invalidPhone.tr();
  return null;
}

// ✅ Optional phone (لا إلزام)
String? _validateOptionalPhone(String? v) {
  if (v == null || v.trim().isEmpty) return null; // اختياري
  if (v.trim().length < 9) return LocaleKeys.invalidPhone.tr();
  return null;
}

// ✅ Min length
String? _validateMinLength(String? v, int min) {
  if (v == null || v.trim().isEmpty) return LocaleKeys.fieldRequired.tr();
  if (v.trim().length < min) return '${LocaleKeys.minLength.tr()} $min';
  return null;
}
```

> `CustomRegex` من: `core/foundation/utils/validators.dart`

