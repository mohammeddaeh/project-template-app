## 5 · تعطيل الزر أثناء التحميل

```dart
// ✅ الطريقة الموحّدة — isLoading + onTap: null
PrimaryButton(
  text: LocaleKeys.save.tr(),
  isLoading: isLoading,       // يُظهر CircularProgressIndicator
  onTap: isLoading ? null : () => _submit(context),
);

// ✅ إذا احتجت تعطيل بناءً على شرط آخر (مثل: empty field)
PrimaryButton(
  text: LocaleKeys.save.tr(),
  isLoading: isLoading,
  isEnabled: canSubmit,       // يُعتّم الزر
  onTap: (isLoading || !canSubmit) ? null : () => _submit(context),
);
```

### تفعيل/تعطيل الزر في real-time بناءً على الحقول

```dart
// في initState — بعد تهيئة الـ controllers
_emailCtrl.addListener(_refreshSubmitButton);
_passwordCtrl.addListener(_refreshSubmitButton);

// helper
void _refreshSubmitButton() => _refreshCubit.refresh();

// getter
bool get _canSubmit =>
    _emailCtrl.text.isNotEmpty && _passwordCtrl.text.length >= 8;

// في dispose — أزل الـ listeners
@override
void dispose() {
  _emailCtrl.removeListener(_refreshSubmitButton);
  _passwordCtrl.removeListener(_refreshSubmitButton);
  _emailCtrl.dispose();
  _passwordCtrl.dispose();
  _refreshCubit.close();
  super.dispose();
}

// في الـ build — BlocBuilder للزر فقط
BlocBuilder<RefreshCubit, RefreshState>(
  bloc: _refreshCubit,
  builder: (context, _) => PrimaryButton(
    text: LocaleKeys.login.tr(),
    isLoading: isLoading,
    isEnabled: _canSubmit,
    onTap: _canSubmit ? () => _submit(context) : null,
  ),
)
```

