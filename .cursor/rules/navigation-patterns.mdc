## 2 · إضافة Route جديد

```dart
// 1. أضف @RoutePage() على الشاشة
@RoutePage()
class {Name}Screen extends StatelessWidget { ... }

// 2. أضف في router.dart
@AutoRouterConfig()
class AppRouter extends RootStackRouter {
  @override
  List<AutoRoute> get routes => [
    // شاشة عادية مع animation
    customRouteWithAnimation(page: {Name}Route.page),

    // شاشة مع path parameter
    AutoRoute(
      path: '/{feature}/:id',
      page: {Name}Route.page,
    ),

    // شاشة بدون animation (مثل Splash)
    AutoRoute(page: SplashRoute.page, path: '/splash'),
  ];
}

// 3. شغّل build_runner
dart run build_runner build --delete-conflicting-outputs
```

