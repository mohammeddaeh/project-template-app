## 10 · RefreshCubit — إعادة بناء مخصصة في Forms

```dart
// متى: تريد تفعيل/تعطيل زر بناءً على قيمة حقل
// import 'package:flutter_base_template/presentation/shared/refresh/refresh_cubit.dart';

final _refreshCubit = RefreshCubit();

@override
void initState() {
  super.initState();
  // ربط كل controller بالـ refreshCubit
  _emailController.addListener(_refreshCubit.refresh);
  _passwordController.addListener(_refreshCubit.refresh);
}

@override
void dispose() {
  _refreshCubit.close();
  super.dispose();
}

// في الـ build:
BlocBuilder<RefreshCubit, RefreshState>(
  bloc: _refreshCubit,
  builder: (context, _) {
    final canSubmit = _emailController.text.isNotEmpty
        && _passwordController.text.isNotEmpty;
    return PrimaryButton(
      text: LocaleKeys.login.tr(),
      isEnabled: canSubmit,
      onTap: canSubmit ? () => _handleLogin(context) : null,
      isLoading: outerState is LoginLoading,
    );
  },
)
```

