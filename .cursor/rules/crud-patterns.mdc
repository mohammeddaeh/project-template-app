  {Feature}FormRoute(
    id: entity.id,
    initialEntity: entity,
  ),
);
if (didUpdate == true && context.mounted) {
  // خيار 1: تحديث العنصر في الـ list بدون re-fetch كامل
  context.read<{Feature}ListCubit>().replaceEntityItem(updatedEntity);
  // خيار 2: إعادة تحميل الصفحة الحالية كاملاً
