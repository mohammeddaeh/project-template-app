## 7 · Repository — void/Unit للحذف والتعديل

```dart
// Abstract (domain)
abstract class {Feature}Repository {
  Future<Either<Failure, {Entity}>>    getList({PaginationQuery query});
  Future<Either<Failure, {Entity}>>    getDetail(String id);
  Future<Either<Failure, {Entity}>>    create{Feature}(Create{Feature}Params params);
  Future<Either<Failure, {Entity}>>    update{Feature}(Update{Feature}Params params);
  Future<Either<Failure, Unit>>        delete{Feature}(String id);
}

// Impl — DELETE مثال (void response)
@override
Future<Either<Failure, Unit>> delete{Feature}(String id) => handle(() async {
  final res = await _remoteDataSource.delete{Feature}(id);
  if (res.error == null) return const Right(unit);
  return Left(BusinessFailure(statusCode: res.error?.code ?? 400));
});

// Impl — UPDATE مثال (يُرجع الـ entity المحدَّثة)
@override
Future<Either<Failure, {Entity}>> update{Feature}(Update{Feature}Params params) =>
    handle(() async {
      final res = await _remoteDataSource.update{Feature}(params);
      if (res.error == null && res.data != null) {
        return Right(res.data!.toEntity());
      }
      return Left(BusinessFailure(statusCode: res.error?.code ?? 400));
    });
```

