## 1 · FormCubit — الإضافة والتعديل في Cubit واحد

```dart
// lib/Features/{feature}/presentation/cubits/{feature}_form_cubit.dart
import 'package:flutter_base_template/Features/{feature}/domain/entities/{entity}.dart';
import 'package:flutter_base_template/Features/{feature}/domain/usecases/create_{feature}.dart';
import 'package:flutter_base_template/Features/{feature}/domain/usecases/update_{feature}.dart';
import 'package:flutter_base_template/presentation/error/failure_ui_mapper.dart';
import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:freezed_annotation/freezed_annotation.dart';
import 'package:injectable/injectable.dart';

part '{feature}_form_cubit.freezed.dart';
part '{feature}_form_state.dart';

@injectable
class {Feature}FormCubit extends Cubit<{Feature}FormState> {
  {Feature}FormCubit(
    this._create{Feature},
    this._update{Feature},
  ) : super(const {Feature}FormState.initial());

  final Create{Feature} _create{Feature};
  final Update{Feature} _update{Feature};

  // isEditing يُحدَّد من الشاشة بناءً على وجود id
  void submit({
    required String? id,
    required String field1,
    required String? field2,
  }) async {
    emit(const {Feature}FormState.loading());

    final res = id == null
        ? await _create{Feature}(
            Create{Feature}Params(field1: field1, field2: field2),
          )
        : await _update{Feature}(
            Update{Feature}Params(id: id, field1: field1, field2: field2),
          );

    res.fold(
      (failure) {
        switch (FailureUiMapper.toAction(failure)) {
          case ShowError(:final message):
            emit({Feature}FormState.error(errorMessage: message));
          case NavigateToLogin():
            AuthEventBus.instance.emit(AuthEvent.sessionExpired);
          case Silent():
            break;
        }
      },
      (_) => emit(const {Feature}FormState.success()),
    );
  }
}
```

```dart
// lib/Features/{feature}/presentation/cubits/{feature}_form_state.dart
part of '{feature}_form_cubit.dart';

@freezed
abstract class {Feature}FormState with _${Feature}FormState {
  const factory {Feature}FormState.initial()                             = {Feature}FormInitial;
  const factory {Feature}FormState.loading()                             = {Feature}FormLoading;
  const factory {Feature}FormState.success()                             = {Feature}FormSuccess;
  const factory {Feature}FormState.error({required String errorMessage}) = {Feature}FormError;
}
```

