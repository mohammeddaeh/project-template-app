## 2 · FormScreen — شاشة واحدة للإضافة والتعديل

```dart
// lib/Features/{feature}/presentation/pages/{feature}_form_screen.dart
import 'package:auto_route/auto_route.dart';
import 'package:flutter/material.dart';
import 'package:flutter_base_template/resources/locale_keys.g.dart';
import 'package:easy_localization/easy_localization.dart';

@RoutePage()
class {Feature}FormScreen extends StatefulWidget {
  const {Feature}FormScreen({
    super.key,
    // null = إضافة جديدة  /  موجود = تعديل
    @PathParam('id') this.id,
    // entity تُمرَّر للتعديل لملء الحقول مسبقاً
    this.initialEntity,
  });

  final String? id;
  final {Entity}? initialEntity;

  @override
  State<{Feature}FormScreen> createState() => _{Feature}FormScreenState();
}

class _{Feature}FormScreenState extends State<{Feature}FormScreen> {
  final _formKey = GlobalKey<FormState>();
  late final TextEditingController _field1Controller;
  late final TextEditingController _field2Controller;

  bool get _isEditing => widget.id != null;

  @override
  void initState() {
    super.initState();
    // في حالة التعديل: ملء الحقول من الـ entity المُمرَّرة
    _field1Controller = TextEditingController(
      text: widget.initialEntity?.field1 ?? '',
    );
    _field2Controller = TextEditingController(
      text: widget.initialEntity?.field2 ?? '',
    );
  }

  @override
  void dispose() {
    _field1Controller.dispose();
    _field2Controller.dispose();
    super.dispose();
  }

  void _submit(BuildContext context) {
    if (!_formKey.currentState!.validate()) return;
    context.read<{Feature}FormCubit>().submit(
          id: widget.id,
          field1: _field1Controller.text.trim(),
          field2: _field2Controller.text.trim(),
        );
  }

  @override
  Widget build(BuildContext context) {
    return BlocProvider(
      create: (_) => getIt<{Feature}FormCubit>(),
      child: Scaffold(
        appBar: AppBar(
          title: Text(
            _isEditing
                ? LocaleKeys.edit{Feature}.tr()
                : LocaleKeys.add{Feature}.tr(),
          ),
        ),
        body: BlocConsumer<{Feature}FormCubit, {Feature}FormState>(
          listener: (context, state) {
            state.maybeWhen(
              success: () {
                context.feedback.success(
                  _isEditing
                      ? LocaleKeys.updatedSuccessfully.tr()
                      : LocaleKeys.addedSuccessfully.tr(),
                );
                context.router.pop(true); // true = يُخبر الشاشة السابقة بالتحديث
              },
              error: (msg) => context.feedback.error(msg),
              orElse: () {},
            );
          },
          builder: (context, state) {
            final isLoading = state is {Feature}FormLoading;
            return Form(
              key: _formKey,
              child: ListView(
                padding: const EdgeInsets.all(16),
                children: [
                  CustomTextField(
                    controller: _field1Controller,
                    labelText: LocaleKeys.field1Label.tr(),
                    validator: (v) => v == null || v.isEmpty
                        ? LocaleKeys.fieldRequired.tr()
                        : null,
                  ),
                  const SizedBox(height: 16),
                  CustomTextField(
                    controller: _field2Controller,
                    labelText: LocaleKeys.field2Label.tr(),
                  ),
                  const SizedBox(height: 24),
                  PrimaryButton(
                    text: _isEditing
                        ? LocaleKeys.save.tr()
                        : LocaleKeys.add.tr(),
                    isLoading: isLoading,
                    onTap: () => _submit(context),
                  ),
                ],
              ),
            );
          },
        ),
      ),
    );
  }
}
```

### الإضافة من شاشة القائمة

```dart
