## 5 · Validation — قواعد التحقق الموحّدة

```dart
// ✅ required text
validator: (v) => (v == null || v.trim().isEmpty)
    ? LocaleKeys.fieldRequired.tr()
    : null,

// ✅ email
validator: (v) {
  if (v == null || v.isEmpty) return LocaleKeys.fieldRequired.tr();
  if (!RegExp(r'^[\w-.]+@([\w-]+\.)+[\w-]{2,}$').hasMatch(v)) {
    return LocaleKeys.invalidEmail.tr();
  }
  return null;
},

// ✅ password (8-30 + regex)
validator: (v) {
  if (v == null || v.isEmpty) return LocaleKeys.fieldRequired.tr();
  if (v.length < 8 || v.length > 30) return LocaleKeys.passwordLength.tr();
  if (!CustomRegex.passwordRegex.hasMatch(v)) return LocaleKeys.passwordWeak.tr();
  return null;
},

// ✅ phone
validator: (v) {
  if (v == null || v.isEmpty) return LocaleKeys.fieldRequired.tr();
  if (v.length < 9) return LocaleKeys.invalidPhone.tr();
  return null;
},

// ✅ optional (لا تحقق)
validator: null,
```

> استورد `CustomRegex` من: `package:flutter_base_template/core/foundation/utils/validators.dart`

