## 6 · UseCases للـ CRUD

```dart
// create_{feature}.dart
@injectable
class Create{Feature} extends BaseUseCase<Either<Failure, {Entity}>, Create{Feature}Params> {
  Create{Feature}(this._{feature}Repository);
  final {Feature}Repository _{feature}Repository;

  @override
  Future<Either<Failure, {Entity}>> call(covariant Create{Feature}Params params) =>
      _{feature}Repository.create{Feature}(params);
}

class Create{Feature}Params extends UseCaseParams {
  final String field1;
  final String? field2;
  const Create{Feature}Params({required this.field1, this.field2}) : super();
}

// update_{feature}.dart
@injectable
class Update{Feature} extends BaseUseCase<Either<Failure, {Entity}>, Update{Feature}Params> {
  Update{Feature}(this._{feature}Repository);
  final {Feature}Repository _{feature}Repository;

  @override
  Future<Either<Failure, {Entity}>> call(covariant Update{Feature}Params params) =>
      _{feature}Repository.update{Feature}(params);
}

class Update{Feature}Params extends UseCaseParams {
  final String id;
  final String field1;
  final String? field2;
  const Update{Feature}Params({required this.id, required this.field1, this.field2}) : super();
}

// delete_{feature}.dart
@injectable
class Delete{Feature} extends BaseUseCase<Either<Failure, Unit>, Delete{Feature}Params> {
  Delete{Feature}(this._{feature}Repository);
  final {Feature}Repository _{feature}Repository;

  @override
  Future<Either<Failure, Unit>> call(covariant Delete{Feature}Params params) =>
      _{feature}Repository.delete{Feature}(params.id);
}

class Delete{Feature}Params extends UseCaseParams {
  final String id;
  const Delete{Feature}Params({required this.id}) : super();
}
